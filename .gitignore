# JisuCMS .gitignore
# 极速CMS 版本控制忽略文件配置

# ==========================================
# 配置文件（包含敏感信息）
# ==========================================
jisucms/config/conf.php
jisucms/config/plugin.php
jisucms/config/route.php

# ==========================================
# 上传文件目录
# ==========================================
upload/*
!upload/.gitkeep

# ==========================================
# 日志文件
# ==========================================
log/*
!log/.gitkeep

# ==========================================
# 缓存文件
# ==========================================
runcache/*
!runcache/.gitkeep

# ==========================================
# IDE 配置文件
# ==========================================
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (PhpStorm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.project
.buildpath
.settings/

# NetBeans
nbproject/

# ==========================================
# 操作系统文件
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ==========================================
# 临时文件
# ==========================================
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
*.log
*.cache

# ==========================================
# 依赖管理
# ==========================================
# Composer
vendor/
composer.phar
composer.lock

# NPM
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# ==========================================
# 环境配置
# ==========================================
.env
.env.local
.env.*.local

# ==========================================
# 数据库备份
# ==========================================
*.sql
*.sql.gz
*.sql.zip
backup/

# ==========================================
# 压缩文件
# ==========================================
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz

# ==========================================
# Kiro AI 工作目录
# ==========================================
# Kiro AI 的工作文件不需要提交到版本控制
.kiro/

# ==========================================
# 其他
# ==========================================
# 安装锁定文件（安装后生成）
install/install.lock

# 测试文件
test/
tests/
phpunit.xml
.phpunit.result.cache
